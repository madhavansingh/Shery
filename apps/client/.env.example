# ── Frontend API Configuration ──────────────────────────────────────────────
# In development: points to local backend
# In production (Vercel): set to your Railway/Cloud Run backend URL
VITE_API_BASE_URL=http://localhost:5001
VITE_API_DIRECT_URL=http://localhost:5001

# ── IMPORTANT: Security Rules ────────────────────────────────────────────────
# - Only VITE_ prefixed variables are exposed to the browser bundle
# - NEVER put Firebase Admin keys, NVIDIA API keys, or AssemblyAI keys here
# - Firebase CLIENT config (not admin) is safe to expose if needed
# - All sensitive AI service keys belong ONLY in apps/server/.env
