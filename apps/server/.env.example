# ── Runtime ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5001
FRONTEND_URL=http://localhost:5173

# ── Firebase Admin SDK (server-side ONLY — never expose to client) ──────────
# Option A: Individual credentials (recommended for Railway/Cloud Run)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-XXXXX@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----\n"

# Optional Firebase Admin SDK storage config (Not required when using Supabase Storage)
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Option B: Full service account JSON (alternative, base64-encoded)
# FIREBASE_SERVICE_ACCOUNT=base64encodedJsonHere

# ── Redis / BullMQ ──────────────────────────────────────────────────────────
# Local: redis://127.0.0.1:6379
# Upstash: rediss://default:TOKEN@your-upstash-url.upstash.io:6379
REDIS_URL=redis://127.0.0.1:6379

# ── Qdrant Vector Database ──────────────────────────────────────────────────
# Local: http://127.0.0.1:6333
# Qdrant Cloud: https://your-cluster.qdrant.io:6333
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=

# ── NVIDIA NIM ─────────────────────────────────────────────────────────────
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_MODEL=nvidia/nemotron-3-nano-30b-a3b
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-mistral-7b-v2

# ── AssemblyAI ──────────────────────────────────────────────────────────────
ASSEMBLYAI_API_KEY=your-assemblyai-key
ASSEMBLYAI_SPEECH_MODELS=universal-3-pro,universal-2
TRANSCRIPTION_PROVIDER=assemblyai

# ── File Storage ─────────────────────────────────────────────────────────────
# 'local' (development / Railway scratch) | 'supabase' (production free-tier)
STORAGE_PROVIDER=local

# ── Supabase Storage (production free-tier — replaces Google Cloud Storage) ──
# Create a project at: https://supabase.com → Project → Storage → Create bucket
# Bucket should be private (we generate signed URLs server-side)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_STORAGE_BUCKET=workspace-assets
SUPABASE_SIGNED_URL_TTL_SECONDS=3600

# ── Upload Limits ────────────────────────────────────────────────────────────
MAX_VIDEO_UPLOAD_MB=100
WORKSPACE_MAX_PDF_MB=20

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
ALLOW_VERCEL_PREVIEWS=false     # Set to 'true' to allow *.vercel.app preview URLs

# ── Knowledge Workspace Limits ───────────────────────────────────────────────
WORKSPACE_FREE_LIMIT=50
WORKSPACE_SOURCE_LIMIT=20
WORKSPACE_CHUNK_SIZE_TOKENS=384
WORKSPACE_CHUNK_OVERLAP_TOKENS=48
